# Dominio web de Nextcloud (NPM en .11 enruta aquí)
DOMAIN=email.escardar.com

# FQDN del servidor de correo (SMTP/IMAP)
MAIL_HOSTNAME=mail.escardar.com

# Credenciales de Base de Datos MariaDB
MYSQL_ROOT_PASSWORD=escardar_db_pass
MYSQL_PASSWORD=escardar_db_pass
NEXTCLOUD_DB_NAME=nextcloud
NEXTCLOUD_DB_USER=nextcloud

# Administrador de Nextcloud
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=admin
